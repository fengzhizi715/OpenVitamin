###############################################################################
# 1. 依赖 / 构建产物（必须忽略）
###############################################################################
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

build/
dist/
out/
target/
bin/
obj/
cmake-build*/
.vscode/
.idea/

.gradle/
.kotlinc/
.kotlin/
__pycache__/
*.pyc

###############################################################################
# 2. AI / ML 模型与大文件（Cursor 扫了只会炸内存）
###############################################################################

checkpoints/
weights/
onnx/
*.onnx
*.pth
*.pt
*.bin
*.safetensors
*.gguf
*.ggml
*.ckpt

###############################################################################
# 3. 数据 / 缓存 / RAG 索引（只忽略明确的数据目录，不误伤业务代码）
###############################################################################
# 仅忽略根目录 data、以及 backend 运行时数据；不忽略 backend/core/data/（ORM/向量检索代码）
/data/
backend/data/
dataset/
datasets/
samples/
assets/raw/
assets/cache/
cache/
.caches/
.cache/
# 不全局忽略 rag/，否则会隐藏 backend/core/rag/、plugins/builtin/rag/ 等业务代码
# 若存在 RAG 索引目录，可单独加例如：backend/data/rag_index/
vector_store/
embeddings/

###############################################################################
# 4. 媒体资源（你的视频 / 图片工程一定有）
###############################################################################
*.mp4
*.mov
*.mkv
*.avi
*.webm
*.wav
*.mp3
*.flac
*.png
*.jpg
*.jpeg
*.webp
*.tiff
*.psd

###############################################################################
# 5. 第三方源码 / 子模块（除非你真的要改它）
###############################################################################
third_party/
3rdparty/
external/
vendor/
deps/

###############################################################################
# 6. 平台 / 系统杂项
###############################################################################
.DS_Store
Thumbs.db
*.log
*.tmp
*.bak
*.swp

###############################################################################
# 7. 你可以「选择性开启」的重资源（默认关）
###############################################################################
# 如果你在调试这些模块，可以临时删掉对应行
# cpp/generated/
# build_release/
# android/.cxx/
# ios/Pods/

###############################################################################
# 8. Git 本身（Cursor 扫 .git 非常吃内存）
###############################################################################
.git/